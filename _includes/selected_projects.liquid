{% assign research_projects = site.projects | where: 'category', 'research' | sort: 'start_sort' | reverse %}

<div class="selected-projects">
  <ul>
    {% for project in research_projects %}
      <li>
        <strong>{{ project.title }}</strong>
        <span class="selected-project-period">{{ project.period }}</span>
      </li>
    {% endfor %}
  </ul>
</div>
